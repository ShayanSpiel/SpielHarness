# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=

# Model provider
MISTRAL_API_KEY=

# Public application origin used for OAuth redirect URIs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (Gmail, Calendar, Analytics)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Notion public integration OAuth
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Optional dedicated key for encrypting OAuth tokens at rest.
# If omitted, SUPABASE_SECRET_KEY is used as the encryption source.
CONNECTION_ENCRYPTION_KEY=

# Optional search providers
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
