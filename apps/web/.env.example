# Database (any Postgres 14+ — Supabase, Neon, RDS, local, etc.)
DATABASE_URL=postgres://postgres:postgres@localhost:54322/postgres

# Model providers (server-side only)
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
MISTRAL_MEDIUM_MODEL=mistral-medium-3-5
MISTRAL_MEDIUM_MODEL_NAME=Mistral Medium 3.5
MISTRAL_MEDIUM_CONTEXT_WINDOW=256000
MISTRAL_MEDIUM_MAX_OUTPUT_TOKENS=32768
MISTRAL_MEDIUM_REASONING_EFFORT=high
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional base URLs for compatible providers
MISTRAL_BASE_URL=
OPENAI_BASE_URL=
ANTHROPIC_BASE_URL=
GEMINI_BASE_URL=

# Public application origin (OAuth redirect target)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# BetterAuth base URL (must match NEXT_PUBLIC_APP_URL)
BETTER_AUTH_URL=http://localhost:3000

# Encryption secret for stored credentials
CONNECTION_ENCRYPTION_KEY=

# Google OAuth (Gmail, Calendar, Drive, Analytics)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Notion OAuth
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:3000/api/auth/notion/callback

# Resend (transactional emails — invites, etc.)
RESEND_API_KEY=re_jEXNU5k3_3QDyGa4TZysYgGX3N1QfRoVH
RESEND_FROM_EMAIL=shayan@spielos.xyz
