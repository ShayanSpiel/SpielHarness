{
  "name": "spielos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @spielos/web",
    "build": "npm run build --workspace @spielos/web",
    "lint": "npm run lint --workspace @spielos/web",
    "check:ui": "npm run check:colors --workspace @spielos/web && bash scripts/check-ui-contracts.sh",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:live": "npx playwright test --headed",
    "test:e2e:update": "npx playwright test --update-snapshots",
    "db:verify": "bash scripts/db-verify.sh",
    "db:migrate": "bash scripts/db-migrate.sh",
    "db:seed": "bash scripts/db-seed.sh",
    "db:reset": "bash scripts/db-reset.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "typescript": "^6.0.0"
  },
  "dependencies": {
    "@boxicons/react": "^1.0.3",
    "better-auth": "^1.6.23",
    "geist": "^1.7.2",
    "sharp": "^0.35.3"
  }
}
