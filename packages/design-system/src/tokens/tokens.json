{
  "radius": {
    "sm": 4,
    "md": 6,
    "lg": 10,
    "xl": 14
  },
  "duration": {
    "fast": 120,
    "default": 160,
    "slow": 240
  },
  "ease": "cubic-bezier(0.2, 0.8, 0.2, 1)",
  "fonts": {
    "sans": ["var(--font-outfit)", "ui-sans-serif", "system-ui", "-apple-system", "Segoe UI", "Inter", "Helvetica Neue", "Arial", "sans-serif"],
    "mono": ["var(--font-jetbrains-mono)", "ui-monospace", "SFMono-Regular", "JetBrains Mono", "Fira Code", "Menlo", "Consolas", "monospace"]
  },
  "shadows": {
    "panel": "0 1px 0 color-mix(in oklab, var(--border) 50%, transparent)",
    "popover": "0 8px 24px color-mix(in oklab, var(--background-deep) 60%, transparent)"
  }
}
