{
  "radius": {
    "sm": 4,
    "md": 6,
    "lg": 10,
    "xl": 14,
    "pill": 999
  },
  "duration": {
    "fast": 120,
    "default": 160,
    "slow": 240
  },
  "motion": {
    "distanceSm": 4,
    "scaleIn": 0.985
  },
  "layout": {
    "sidebarListResponsiveMax": "38vw",
    "editorFieldMin": "10rem",
    "editorFieldMinCompact": "9.375rem"
  },
  "interaction": {
    "focusBorder": "color-mix(in oklab, var(--ring) 42%, var(--border-strong))",
    "focusRing": "color-mix(in oklab, var(--ring) 18%, transparent)",
    "disabledSurface": "color-mix(in oklab, var(--input) 58%, var(--panel) 42%)",
    "disabledBorder": "color-mix(in oklab, var(--border) 68%, transparent)",
    "disabledForeground": "color-mix(in oklab, var(--muted-foreground) 72%, transparent)"
  },
  "fontSize": {
    "3xs": 10,
    "2xs": 11,
    "editor": 15
  },
  "lineHeight": {
    "tight": 1.25,
    "snug": 1.375,
    "normal": 1.5,
    "relaxed": 1.625
  },
  "ease": "cubic-bezier(0.2, 0.8, 0.2, 1)",
  "fonts": {
    "sans": ["var(--font-outfit)", "ui-sans-serif", "system-ui", "-apple-system", "Segoe UI", "Inter", "Helvetica Neue", "Arial", "sans-serif"],
    "mono": ["var(--font-jetbrains-mono)", "ui-monospace", "SFMono-Regular", "JetBrains Mono", "Fira Code", "Menlo", "Consolas", "monospace"]
  },
  "shadows": {
    "panel": "0 1px 0 color-mix(in oklab, var(--border) 50%, transparent)",
    "popover": "0 8px 24px color-mix(in oklab, var(--background-deep) 60%, transparent)"
  }
}
